# =============================================================================
# .gitignore
# Files and folders to exclude from the GitHub repository
# =============================================================================

# ── Datasets (too large for GitHub) ──────────────────────────────────────────
*.csv
dataset/
data/raw/

# ── Preprocessed data ─────────────────────────────────────────────────────────
preprocessed_*.csv

# ── Saved models and checkpoints ──────────────────────────────────────────────
*.pt
*.bin
*.pkl
*.h5
t5-title-gen/
checkpoints/

# ── GloVe vectors ─────────────────────────────────────────────────────────────
*.txt.gz
glove*/

# ── Results ───────────────────────────────────────────────────────────────────
results_*.json

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.env
.venv/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
runs/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp